# Copy to .env and fill in (never commit .env)

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google — YouTube Data API v3 key (AIza...) or OAuth access token
YOUTUBE_API_KEY=

# Channel to analyze (UC...)
YOUTUBE_CHANNEL_ID=

# App login (single shared password for your team)
TUBERANK_PASSWORD=You$$$Tube

# Notion — internal integration secret (optional)
NOTION_TOKEN=

# Notion context page UUID or full URL (required if NOTION_TOKEN is set)
NOTION_PAGE_ID=
